<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario de Contacto</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }
        .container {
            background: #fff;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 500px;
        }
        h2 { color: #333; text-align: center; margin-bottom: 1.5rem; }
        .form-group { margin-bottom: 1.2rem; }
        label { display: block; margin-bottom: 0.5rem; color: #666; font-weight: 600; }
        input, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            box-sizing: border-box; /* Importante para el ancho total */
            font-size: 1rem;
        }
        input:focus, textarea:focus { border-color: #039be5; outline: none; }
        textarea { height: 100px; resize: vertical; }
        .btn-submit {
            background-color: #039be5;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            font-size: 1.1rem;
            font-weight: bold;
            transition: background 0.3s;
        }
        .btn-submit:hover { background-color: #0277bd; }
        .file-help { font-size: 0.8rem; color: #888; margin-top: 4px; }
    </style>
</head>
<body>

<div class="container">
    <h2>Envíame tu información</h2>
    
    <form action="https://formspree.io/f/TU_ID_AQUÍ" method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
            <label for="nombre">Nombre y Apellidos</label>
            <input type="text" name="nombre" id="nombre" placeholder="Tu nombre completo" required>
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" name="_replyto" id="email" placeholder="ejemplo@correo.com" required>
        </div>

        <div class="form-group">
            <label for="archivo">Subir archivos</label>
            <input type="file" name="upload" id="archivo">
            <p class="file-help">Admite cualquier formato (PDF, JPG, ZIP, etc.)</p>
        </div>

        <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea name="mensaje" id="mensaje" placeholder="¿En qué puedo ayudarte?"></textarea>
        </div>

        <input type="hidden" name="_to" value="theremendao99@gmail.com">

        <button type="submit" class="btn-submit">Enviar datos</button>
    </form>
</div>

</body>
</html>
